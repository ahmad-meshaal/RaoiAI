# Server Configuration
PORT=5000
NODE_ENV=production
SESSION_SECRET=your-very-secret-key-change-this

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/rawi_db

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# Firebase Configuration (Optional: for cloud storage)
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-auth-domain.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-database-url.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-storage-bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Optional: If using a custom base URL or Replit AI

# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# AI Integrations (Replit specific, but good to have)
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key
